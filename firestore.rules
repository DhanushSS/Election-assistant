rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Election data (public read, no write from client) ─────────────────
    match /election_data/{document=**} {
      allow read: if true;
      allow write: if false;  // Only Cloud Run backend can write via Admin SDK
    }

    // ── Conversations — anonymous session-based ────────────────────────────
    match /conversations/{sessionId} {
      // Allow if sessionId looks like a UUID (36 chars)
      allow read: if sessionId.size() == 36;
      allow write: if false;  // Backend-only via Admin SDK

      match /messages/{messageId} {
        allow read: if sessionId.size() == 36;
        allow write: if false;  // Backend-only via Admin SDK
      }
    }

    // ── Block everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
