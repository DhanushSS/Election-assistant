# VoteAI India — Frontend Environment Variables
# Copy this to .env.local and fill in your values

# Backend Cloud Run URL (after deployment)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080

# Firebase (Firestore only — no Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=election-assistant-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=election-assistant-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=election-assistant-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
